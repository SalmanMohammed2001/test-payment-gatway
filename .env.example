# Copy to .env and fill in a WORKING CyberSource sandbox account.
# ./run.sh loads this automatically. .env is git-ignored.
#
# Get these from https://developer.cybersource.com (a fresh sandbox account
# is normally pre-provisioned with a test processor, which fixes the
# "General system failure" / Processing Error).

# ---- REST API (Key Management → REST Shared Secret) ----
CYBS_MERCHANT_ID=
CYBS_MERCHANT_KEY_ID=
CYBS_MERCHANT_SECRET_KEY=
CYBS_RUN_ENVIRONMENT=apitest.cybersource.com

# ---- Secure Acceptance (Secure Acceptance Settings → profile → Security) ----
SA_PROFILE_ID=
SA_ACCESS_KEY=
SA_SECRET_KEY=
SA_PAY_URL=https://testsecureacceptance.cybersource.com/pay
SA_FRONTEND_RESULT_URL=http://localhost:4200/checkout/result
CYBS_DEFAULT_CURRENCY=LKR
SA_DEFAULT_CURRENCY=LKR

# ---- Database ----
DB_USERNAME=root
DB_PASSWORD=Salman123!
